# =============================================================================
# Deal Hunter — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets and machine-specific config (NEVER commit these)
# -----------------------------------------------------------------------------
.env
local.yaml

# -----------------------------------------------------------------------------
# Database (lives in data/, only .gitkeep is tracked)
# -----------------------------------------------------------------------------
data/*.db
data/*.db-shm
data/*.db-wal

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# mypy / pyright
.mypy_cache/
.pyright/
pyrightconfig.json

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Editors and IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# -----------------------------------------------------------------------------
# Temporary / scratch files
# -----------------------------------------------------------------------------
*.tmp
*.bak
scratch/
