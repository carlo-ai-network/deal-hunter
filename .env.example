# Deal Hunter — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.

# eBay API credentials (from developer.ebay.com)
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret

# Reddit API credentials (from reddit.com/prefs/apps — Script type app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ntfy.sh topic (use a long random string — this is the only "auth" for notifications)
NTFY_TOPIC=deal-hunter-your-random-string-here

# Internal API secret (shared between orchestrator and scoring worker)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_SECRET=your_random_secret_here
